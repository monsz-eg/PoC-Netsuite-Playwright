# NetSuite test account credentials
# Copy this file to .env and fill in the values
# .env is gitignored — never commit it

# Which accounts this developer uses — comma-separated, no spaces
# Each developer should use a non-overlapping set to avoid session conflicts
TEST_USERS=nstest1,nstest2,nstest3

NSTEST1_EMAIL=nstest1@eg.dk
NSTEST1_PASSWORD=

NSTEST2_EMAIL=nstest2@eg.dk
NSTEST2_PASSWORD=

NSTEST3_EMAIL=nstest3@eg.dk
NSTEST3_PASSWORD=

NSTEST4_EMAIL=nstest4@eg.dk
NSTEST4_PASSWORD=

NSTEST5_EMAIL=nstest5@eg.dk
NSTEST5_PASSWORD=

NSTEST6_EMAIL=nstest6@eg.dk
NSTEST6_PASSWORD=
